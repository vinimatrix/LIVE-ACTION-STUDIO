### 5.2 Video Assembly
Executed by Editor Agent using FFmpeg:

**Command Simulated:**
```
ffmpeg \
  -i "concat:assets/video/segments/shot01_eyes_opening.mp4|assets/video/segments/shot02_hands_examining.mp4|assets/video/segments/shot03_realization.mp4|assets/video/segments/shot04_room_context.mp4" \
  -i "assets/audio/voice/jinwoo_what_happened.wav" \
  -i "assets/audio/voice/jinwoo_im_alive.wav" \
  -i "assets/audio/music/opening_theme_awakening.wav" \
  -i "assets/audio/fx/system_awakening_ambience.wav" \
  -i "assets/audio/foley/blanket_rustle.wav" \
  -i "assets/audio/foley/heart_monitor_beep.wav" \
  -i "assets/audio/foley/fingers_on_rail.wav" \
  -i "assets/audio/foley/slow_breath.wav" \
  -i "assets/video/fx/system_glow_overlay.mov" \
  -filter_complex "\
    [0:v][8:v]overlay=enable='between(t,0,8)':enable='gte(t,0.5)':enable='lte(t,7.5)'[vout]; \
    [1:a:]; \
    [1:a]atrim=0.3:2.1,asetpts=PTS-STARTPTS[ad1]; \
    [2:a]atrim=3.8:6.0,asetpts=PTS-STARTPTS[ad2]; \
    [3:a]volume=0.8[amusic]; \
    [4:a]volume=0.6[afx]; \
    [5:a]atrim=0.2:0.4,asetpts=PTS-STARTPTS[afoley1]; \
    [6:a]atrim=0.5:0.6,asetpts=PTS-STARTPTS,atrim=2.0:2.1,asetpts=PTS-STARTPTS,atrim=3.5:3.6,asetpts=PTS-STARTPTS,atrim=5.0:5.1,asetpts=PTS-STARTPTS[afoley2]; \
    [7:a]atrim=1.2:1.4,asetpts=PTS-STARTPTS,atrim=2.8:3.0,asetpts=PTS-STARTPTS[afoley3]; \
    [9:a]atrim=0.8:1.0,asetpts=PTS-STARTPTS,atrim=2.2:2.4,asetpts=PTS-STARTPTS,atrim=4.5:4.7,asetpts=PTS-STARTPTS[afoley4]; \
    [ad1][ad2]amix=inputs=2:duration=first:dropout_transition=3[adialog]; \
    [amusic][afx]amix=inputs=2:duration=first:dropout_transition=2[amusicfx]; \
    [afoley1][afoley2][afoley3][afoley4]amix=inputs=4:duration=first:dropout_transition=2[afoley]; \
    [adialog][amusicfx][afoley]amix=inputs=3:duration=longest:dropout_transition=2[aout] \
  " \
  -map "[vout]" -map "[aout]" \
  -c:v libx264 -preset slow -crf 18 -pix_fmt yuv420p10le \
  -c:a aac -b:a 320k \
  -r 24 \
  -shortest \
  outputs/final/solo_leveling_hospital_awakening_final.mp4
```

